{
  "permissions": {
    "allow": [
      "Bash(bun run typecheck)",
      "Bash(bun run check)",
      "Bash(bun run check:file-docs)",
      "Bash(bun run check:*)",
      "Bash(bun run lint)",
      "Bash(bun run build)",
      "Bash(bun run test)",
      "Bash(bun test)",
      "mcp__claude-in-chrome__get_page_text"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/secret-guard.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/eval-gate.sh\""
          }
        ]
      }
    ]
  }
}
